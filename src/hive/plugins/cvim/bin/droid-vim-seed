#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path

from _droid_vim_shared import capture_session_seed, write_seed


def main() -> int:
    args = sys.argv[1:]
    if len(args) in {2, 3}:
        cwd = args[0]
        dst = Path(args[1])
        preferred = Path(args[2]) if len(args) == 3 and args[2] else None
        write_seed(cwd, dst, preferred)
        return 0

    if len(args) == 6:
        capture_session_seed(
            cwd=args[0],
            dst=Path(args[1]),
            session_map_file=args[2],
            pid=args[3],
            tty=args[4],
            droid_args=args[5],
        )
        return 0

    raise SystemExit("usage: droid-vim-seed <cwd> <dst> [preferred] | <cwd> <dst> <session_map_file> <pid> <tty> <droid_args>")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
