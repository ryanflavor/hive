#!/usr/bin/env python3
from __future__ import annotations

import sys

from _droid_vim_shared import resolve_transcript_path


def main() -> int:
    transcript_path = resolve_transcript_path(
        session_map_file=sys.argv[1],
        cwd=sys.argv[2],
        pid=sys.argv[3],
        tty=sys.argv[4],
        droid_args=sys.argv[5],
    )
    if transcript_path:
        print(transcript_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
