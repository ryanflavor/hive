#!/usr/bin/env python3
from __future__ import annotations

import difflib
import json
import sys
from pathlib import Path
from typing import Any


def _protocol(script_path: Path) -> dict[str, Any]:
    path = script_path.resolve().parent.parent / "resources" / "droid_edit_protocol.json"
    return json.loads(path.read_text())


def _build_payload(orig: str, edited: str, mode: str, protocol: dict[str, Any]) -> str:
    if mode == "diff":
        diff = "".join(
            difflib.unified_diff(
                orig.splitlines(True),
                edited.splitlines(True),
                fromfile="before",
                tofile="after",
            )
        ).rstrip("\n")
        payload = "<droid_edit mode=\"diff\">\n"
        payload += f"<edit_target>{protocol['diffTarget']}</edit_target>\n"
        payload += f"<edit_note>{protocol['diffNote']}</edit_note>\n"
        payload += "<edit_diff>\n"
        payload += diff
        payload += "\n</edit_diff>\n</droid_edit>"
        return payload

    payload = "<droid_edit mode=\"text\">\n"
    payload += f"<edit_note>{protocol['textNote']}</edit_note>\n"
    payload += "<edited_text>\n"
    payload += edited.rstrip("\n")
    payload += "\n</edited_text>\n</droid_edit>"
    return payload


def main() -> int:
    orig = Path(sys.argv[1]).read_text(errors="ignore")
    edited = Path(sys.argv[2]).read_text(errors="ignore")
    dst = Path(sys.argv[3])
    mode = sys.argv[4]
    payload = _build_payload(orig, edited, mode, _protocol(Path(__file__)))
    dst.write_text(payload[:-1] if payload.endswith("\n") else payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
