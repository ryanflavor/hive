#!/usr/bin/env python3
from __future__ import annotations

import sys

from _cvim_shared import resolve_transcript_path_for_pane


def main() -> int:
    args = sys.argv[1:]
    if len(args) not in {5, 6}:
        raise SystemExit(
            "usage: cvim-session <session_map_file> <cwd> <pid> <tty> <droid_args> [pane_id]"
        )

    transcript_path = resolve_transcript_path_for_pane(
        session_map_file=args[0],
        cwd=args[1],
        pid=args[2],
        tty=args[3],
        droid_args=args[4],
        pane_id=args[5] if len(args) == 6 else "",
    )
    if transcript_path:
        print(transcript_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
