#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path

from _cvim_shared import capture_session_seed, write_seed


def main() -> int:
    args = sys.argv[1:]

    # 2-arg: cwd dst
    # 3-arg: cwd dst preferred_transcript
    # 4-arg: cwd dst preferred_transcript offset
    if len(args) in {2, 3, 4}:
        cwd = args[0]
        dst = Path(args[1])
        preferred = Path(args[2]) if len(args) >= 3 and args[2] else None
        offset = int(args[3]) if len(args) >= 4 and args[3] else 0
        write_seed(cwd, dst, preferred, offset=offset)
        return 0

    # 6-arg: cwd dst session_map_file pid tty droid_args
    # 7-arg: cwd dst session_map_file pid tty droid_args offset
    if len(args) in {6, 7}:
        offset = int(args[6]) if len(args) >= 7 and args[6] else 0
        capture_session_seed(
            cwd=args[0],
            dst=Path(args[1]),
            session_map_file=args[2],
            pid=args[3],
            tty=args[4],
            droid_args=args[5],
            offset=offset,
        )
        return 0

    raise SystemExit("usage: cvim-seed <cwd> <dst> [preferred] [offset] | <cwd> <dst> <session_map_file> <pid> <tty> <droid_args> [offset]")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
