#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
  echo "/vim requires tmux." >&2
  exit 1
fi

editor_bin="${DROID_VIM_EDITOR:-vim}"
if ! command -v "$editor_bin" >/dev/null 2>&1; then
  echo "editor not found: $editor_bin" >&2
  exit 1
fi

seed_mode="${DROID_VIM_SEED_MODE:-blank}"
reply_pane="${TMUX_PANE:-}"
if [[ -n "$reply_pane" ]] && ! tmux display-message -p -t "$reply_pane" '#{pane_id}' >/dev/null 2>&1; then
  reply_pane=""
fi
src_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
if [[ -z "$src_pane" ]]; then
  src_pane="$reply_pane"
fi
if [[ -z "$src_pane" ]]; then
  echo "/vim could not resolve current tmux pane." >&2
  exit 1
fi
if [[ -z "$reply_pane" ]]; then
  reply_pane="$src_pane"
fi
src_cwd="$(tmux display-message -p -t "$src_pane" '#{pane_current_path}')"
src_session="$(tmux display-message -p -t "$src_pane" '#{session_id}')"
src_window="$(tmux display-message -p -t "$src_pane" '#{window_id}')"
src_pane_pid="$(tmux display-message -p -t "$src_pane" '#{pane_pid}')"
src_pane_tty="$(tmux display-message -p -t "$src_pane" '#{pane_tty}')"
src_pane_tty_key="${src_pane_tty#/dev/}"
src_client_tty="$(tmux display-message -p -t "$src_pane" '#{client_tty}')"
src_client_pid="$(tmux display-message -p -t "$src_pane" '#{client_pid}')"
script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
seed_helper="$script_dir/droid-vim-seed"
session_helper="$script_dir/droid-vim-session"
payload_builder="$script_dir/droid-vim-payload"
tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/droid-vim.XXXXXX")"
msg_file="$tmpdir/message.md"
orig_file="$tmpdir/original.md"
helper_file="$tmpdir/run.sh"
debug_root="${DROID_VIM_DEBUG_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/droid-vim/debug}"
mkdir -p "$debug_root" >/dev/null 2>&1 || true
debug_log_file="$(mktemp "${debug_root}/cvim.XXXXXX" 2>/dev/null || true)"
if [[ -z "$debug_log_file" ]]; then
  debug_log_file="$debug_root/latest.log"
  : > "$debug_log_file" 2>/dev/null || true
fi
printf '%s\n' "$debug_log_file" > "$debug_root/latest" 2>/dev/null || true
iterm2_api_dir="${DROID_VIM_ITERM2_API_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/droid-vim/iterm2py}"
ghostty_app="${DROID_VIM_GHOSTTY_APP:-/Applications/Ghostty.app}"
iterm2_window_x="${DROID_VIM_ITERM2_WINDOW_X:-}"
iterm2_window_y="${DROID_VIM_ITERM2_WINDOW_Y:-}"
iterm2_window_width="${DROID_VIM_ITERM2_WINDOW_WIDTH:-1180}"
iterm2_window_height="${DROID_VIM_ITERM2_WINDOW_HEIGHT:-820}"
transport="${DROID_VIM_TRANSPORT:-auto}"
popup_width="${DROID_VIM_POPUP_WIDTH:-}"
popup_height="${DROID_VIM_POPUP_HEIGHT:-}"
split_direction="${DROID_VIM_SPLIT_DIRECTION:-right}"
session_map_file="${HIVE_SESSION_MAP_FILE:-${DROID_VIM_SESSION_MAP_FILE:-${XDG_CACHE_HOME:-$HOME/.cache}/hive/session-map.json}}"
output_mode="${DROID_VIM_OUTPUT_MODE:-text}"
cursor_mode="${DROID_VIM_CURSOR_MODE:-start}"
default_paste_delay="0.20"
if [[ "$transport" == "popup" ]]; then
  default_paste_delay="0.60"
fi
paste_delay_default="${DROID_VIM_PASTE_DELAY:-$default_paste_delay}"
interrupt_before_paste_default="${DROID_VIM_INTERRUPT_BEFORE_PASTE:-1}"
interrupt_after_paste_default="${DROID_VIM_INTERRUPT_AFTER_PASTE:-1}"
interrupt_settle_delay_default="${DROID_VIM_INTERRUPT_SETTLE_DELAY:-0.08}"
submit_delay_default="${DROID_VIM_SUBMIT_DELAY:-0.03}"

debug_log() {
  local message="$1"
  {
    printf '%s pid=%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$$" "$message"
  } >> "$debug_log_file" 2>/dev/null || true
}

case "$cursor_mode" in
  start|top|auto)
    cursor_mode="start"
    ;;
  end)
    ;;
  *)
    cursor_mode="start"
    ;;
esac

if [[ "$seed_mode" == "session" ]]; then popup_title="hive-cvim"; else popup_title="hive-vim"; fi

case "$output_mode" in
  text|diff)
    ;;
  auto)
    if [[ "$seed_mode" == "session" ]]; then
      output_mode="diff"
    else
      output_mode="text"
    fi
    ;;
  *)
    output_mode="text"
    ;;
esac

capture_session_seed_to_file() {
  local cwd="$1"
  local dst="$2"
  local droid_pid="${3:-}"
  local droid_tty="${4:-}"
  local droid_args="${5:-}"
  local seed_offset="${6:-0}"
  "$seed_helper" "$cwd" "$dst" "$session_map_file" "$droid_pid" "$droid_tty" "$droid_args" "$seed_offset"
}

resolve_current_droid_process_info() {
  python3 - "$src_pane_pid" "$src_pane_tty" <<'PY'
import subprocess
import sys

root = int(sys.argv[1])
pane_tty = sys.argv[2]
out = subprocess.check_output(['ps', '-axo', 'pid=,ppid=,tty=,comm=,args='], text=True)
rows = []
for line in out.splitlines():
    parts = line.strip().split(None, 4)
    if len(parts) < 5:
        continue
    pid, ppid, tty, comm, args = int(parts[0]), int(parts[1]), parts[2], parts[3], parts[4]
    rows.append((pid, ppid, tty, comm, args))

by_ppid = {}
for row in rows:
    by_ppid.setdefault(row[1], []).append(row)

best = None
stack = [root]
seen = set()
while stack:
    pid = stack.pop()
    if pid in seen:
        continue
    seen.add(pid)
    for child in by_ppid.get(pid, []):
        child_pid, _, tty, comm, args = child
        if comm == 'droid':
            if best is None or tty == pane_tty:
                best = child
                if tty == pane_tty:
                    print(f'{child_pid}\t{tty}\t{args}')
                    raise SystemExit(0)
        stack.append(child_pid)

if best is not None:
    print(f'{best[0]}\t{best[2]}\t{best[4]}')
PY
}

resolve_current_droid_transcript_path() {
  local info droid_pid="" droid_tty="" droid_args=""
  local transcript_path=""

  if info="$(resolve_current_droid_process_info 2>/dev/null)" && [[ -n "$info" ]]; then
    IFS=$'\t' read -r droid_pid droid_tty droid_args <<<"$info"
  fi

  transcript_path="$("$session_helper" "$session_map_file" "$src_cwd" "$droid_pid" "$droid_tty" "$droid_args")"
  if [[ -n "$transcript_path" && -f "$transcript_path" ]]; then
    printf '%s\n' "$transcript_path"
    return 0
  fi

  return 1
}

ensure_iterm2_python_api() {
  mkdir -p "$iterm2_api_dir"
  if PYTHONPATH="$iterm2_api_dir" python3 - <<'PY' >/dev/null 2>&1
import iterm2  # noqa: F401
import google.protobuf  # noqa: F401
PY
  then
    return 0
  fi

  python3 -m pip install --quiet --target "$iterm2_api_dir" iterm2==2.14 protobuf >/dev/null 2>&1
}

build_helper_cmd() {
  printf '%q ' "$helper_file" "$reply_pane" "$editor_bin" "$msg_file" "$orig_file" "$tmpdir" "$output_mode" "$paste_delay_default" "$interrupt_before_paste_default" "$interrupt_after_paste_default" "$interrupt_settle_delay_default" "$submit_delay_default" "$cursor_mode" "$payload_builder" "$transport" "$debug_log_file"
}

queue_post_run() {
  local content_state_file="$tmpdir/content_changed"
  local send_file="$tmpdir/send.txt"
  local post_file="$tmpdir/post.sh"
  local content_changed="0"
  local send_exists="0"
  local send_bytes="0"

  if [[ -f "$content_state_file" ]]; then
    content_changed="$(cat "$content_state_file" 2>/dev/null || printf '0')"
  fi

  if [[ ! -f "$post_file" ]]; then
    debug_log "queue_post_run.skip post_file=missing tmpdir=$tmpdir content_changed=$content_changed"
    rm -rf "$tmpdir"
    return 0
  fi

  if [[ -f "$send_file" ]]; then
    send_exists="1"
    send_bytes="$(wc -c < "$send_file" | tr -d '[:space:]')"
  fi

  debug_log "queue_post_run.enqueue tmpdir=$tmpdir content_changed=$content_changed send_exists=$send_exists send_bytes=$send_bytes"
  printf -v post_cmd '%q ' "$post_file" "$reply_pane" "$send_file" "$tmpdir" "$paste_delay_default" "$content_changed" "$interrupt_before_paste_default" "$interrupt_after_paste_default" "$interrupt_settle_delay_default" "$submit_delay_default" "$debug_log_file"
  tmux run-shell -b "$post_cmd"
}

debug_log "command.start transport=$transport seed_mode=$seed_mode output_mode=$output_mode src_pane=$src_pane reply_pane=$reply_pane cwd=$src_cwd tmpdir=$tmpdir session_map=$session_map_file"

tmux_supports_popup() {
  local commands
  commands="$(tmux list-commands 2>/dev/null || true)"
  [[ "$commands" == *$'\ndisplay-popup '* || "$commands" == display-popup* ]]
}

resolve_tmux_target_client() {
  local client_tty
  if [[ -n "$src_client_tty" ]]; then
    printf '%s\n' "$src_client_tty"
    return 0
  fi

  client_tty="$(tmux list-clients -t "$src_session" -F '#{client_activity} #{client_tty}' 2>/dev/null | sort -rn | awk 'NF >= 2 { print $2; exit }')"
  [[ -n "$client_tty" ]] || return 1
  printf '%s\n' "$client_tty"
}

resolve_popup_dimension() {
  local spec="$1"
  local total="$2"
  local value

  if [[ "$spec" =~ ^([0-9]+)%$ ]]; then
    value=$(( total * BASH_REMATCH[1] / 100 ))
  elif [[ "$spec" =~ ^[0-9]+$ ]]; then
    value="$spec"
  else
    value=$(( total * 9 / 10 ))
  fi

  if (( value < 1 )); then
    value=1
  elif (( value > total )); then
    value="$total"
  fi

  printf '%s\n' "$value"
}

fit_popup_to_region() {
  local region_x="$1"
  local region_y="$2"
  local region_w="$3"
  local region_h="$4"
  local align="$5"
  local client_w="$6"
  local client_h="$7"
  local width="$region_w"
  local height="$region_h"
  local x y

  if [[ -n "$popup_width" ]]; then
    width="$(resolve_popup_dimension "$popup_width" "$client_w")"
    if (( width > region_w )); then
      width="$region_w"
    fi
  fi

  if [[ -n "$popup_height" ]]; then
    height="$(resolve_popup_dimension "$popup_height" "$client_h")"
    if (( height > region_h )); then
      height="$region_h"
    fi
  fi

  case "$align" in
    right)
      x=$(( region_x + region_w - width ))
      y=$(( region_y + (region_h - height) / 2 ))
      ;;
    left)
      x="$region_x"
      y=$(( region_y + (region_h - height) / 2 ))
      ;;
    bottom)
      x=$(( region_x + (region_w - width) / 2 ))
      y=$(( region_y + region_h - height ))
      ;;
    top)
      x=$(( region_x + (region_w - width) / 2 ))
      y="$region_y"
      ;;
    *)
      x=$(( region_x + (region_w - width) / 2 ))
      y=$(( region_y + (region_h - height) / 2 ))
      ;;
  esac

  printf '%s %s %s %s\n' "$x" "$y" "$width" "$height"
}

resolve_tmux_popup_geometry() {
  local target_client="$1"
  local client_width client_height
  local popup_x popup_y popup_w popup_h
  local pane_id pane_left pane_top pane_width pane_height
  local pane_count
  local pane_lines
  local src_left=0 src_top=0 src_width=0 src_height=0
  local src_center_x src_center_y
  local bb_left bb_top bb_right bb_bottom
  local selected_side
  local bottom_found=0
  local top_found=0

  client_width="$(tmux display-message -p -c "$target_client" '#{client_width}')"
  client_height="$(tmux display-message -p -c "$target_client" '#{client_height}')"
  pane_lines="$(tmux list-panes -t "$src_window" -F '#{pane_id} #{pane_left} #{pane_top} #{pane_width} #{pane_height}' 2>/dev/null || true)"
  pane_count="$(printf '%s\n' "$pane_lines" | awk 'NF >= 5 { count++ } END { print count + 0 }')"

  if (( pane_count <= 1 )); then
    local region_x=$(( client_width / 2 ))
    local region_w=$(( client_width - region_x ))
    read -r popup_x popup_y popup_w popup_h < <(
      fit_popup_to_region "$region_x" 0 "$region_w" "$client_height" "right" "$client_width" "$client_height"
    )
    printf '%s %s %s %s\n' "$popup_x" "$popup_y" "$popup_w" "$popup_h"
    return 0
  fi

  local -a pane_ids=()
  local -a pane_lefts=()
  local -a pane_tops=()
  local -a pane_widths=()
  local -a pane_heights=()
  local i=0

  while read -r pane_id pane_left pane_top pane_width pane_height; do
    [[ -n "$pane_id" ]] || continue
    pane_ids+=("$pane_id")
    pane_lefts+=("$pane_left")
    pane_tops+=("$pane_top")
    pane_widths+=("$pane_width")
    pane_heights+=("$pane_height")
    if [[ "$pane_id" == "$src_pane" ]]; then
      src_left="$pane_left"
      src_top="$pane_top"
      src_width="$pane_width"
      src_height="$pane_height"
    fi
    (( i += 1 ))
  done <<< "$pane_lines"

  local total=${#pane_ids[@]}
  local right_found=0
  local left_found=0
  local pane_center_x pane_center_y

  src_center_x=$(( src_left + src_width / 2 ))
  src_center_y=$(( src_top + src_height / 2 ))

  for (( i=0; i<total; i++ )); do
    [[ "${pane_ids[i]}" == "$src_pane" ]] && continue
    pane_center_x=$(( pane_lefts[i] + pane_widths[i] / 2 ))
    pane_center_y=$(( pane_tops[i] + pane_heights[i] / 2 ))
    if (( pane_center_x > src_center_x )); then
      right_found=1
    elif (( pane_center_x < src_center_x )); then
      left_found=1
    fi
    if (( pane_center_y > src_center_y )); then
      bottom_found=1
    elif (( pane_center_y < src_center_y )); then
      top_found=1
    fi
  done

  selected_side=""
  if (( right_found )); then
    selected_side="right"
  elif (( left_found )); then
    selected_side="left"
  elif (( bottom_found )); then
    selected_side="bottom"
  elif (( top_found )); then
    selected_side="top"
  fi

  bb_left=999999
  bb_top=999999
  bb_right=0
  bb_bottom=0
  local found=0

  for (( i=0; i<total; i++ )); do
    [[ "${pane_ids[i]}" == "$src_pane" ]] && continue
    pane_center_x=$(( pane_lefts[i] + pane_widths[i] / 2 ))
    pane_center_y=$(( pane_tops[i] + pane_heights[i] / 2 ))
    case "$selected_side" in
      right)
        (( pane_center_x > src_center_x )) || continue
        ;;
      left)
        (( pane_center_x < src_center_x )) || continue
        ;;
      bottom)
        (( pane_center_y > src_center_y )) || continue
        ;;
      top)
        (( pane_center_y < src_center_y )) || continue
        ;;
      *)
        continue
        ;;
    esac
    found=1
    local r=$(( pane_lefts[i] + pane_widths[i] ))
    local b=$(( pane_tops[i] + pane_heights[i] ))
    (( pane_lefts[i] < bb_left )) && bb_left=${pane_lefts[i]}
    (( pane_tops[i] < bb_top )) && bb_top=${pane_tops[i]}
    (( r > bb_right )) && bb_right=$r
    (( b > bb_bottom )) && bb_bottom=$b
  done

  if (( found )); then
    read -r popup_x popup_y popup_w popup_h < <(
      fit_popup_to_region \
        "$bb_left" "$bb_top" "$(( bb_right - bb_left ))" "$(( bb_bottom - bb_top ))" \
        "$selected_side" "$client_width" "$client_height"
    )
  else
    local region_x=$(( client_width / 2 ))
    local region_w=$(( client_width - region_x ))
    read -r popup_x popup_y popup_w popup_h < <(
      fit_popup_to_region "$region_x" 0 "$region_w" "$client_height" "right" "$client_width" "$client_height"
    )
  fi

  printf '%s %s %s %s\n' "$popup_x" "$popup_y" "$popup_w" "$popup_h"
}

tmux_client_matches_process() {
  local pattern="$1"
  local pid="$src_client_pid"
  local comm
  local ppid

  while [[ "$pid" =~ ^[0-9]+$ ]] && (( pid > 1 )); do
    comm="$(ps -o comm= -p "$pid" 2>/dev/null | sed 's/^[[:space:]]*//')"
    case "$comm" in
      *"$pattern"* )
        return 0
        ;;
    esac
    ppid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d '[:space:]')"
    [[ -n "$ppid" ]] || break
    pid="$ppid"
  done

  return 1
}

tmux_client_is_iterm2() {
  tmux_client_matches_process "iTerm"
}

tmux_client_is_ghostty() {
  tmux_client_matches_process "Ghostty"
}

start_editor_session() {
  local helper_cmd
  local editor_session_name
  helper_cmd="$(build_helper_cmd)"
  editor_session_name="droid-vim-$(basename "$tmpdir" | tr -cd '[:alnum:]_-')"
  tmux new-session -d -P -F '#{session_name}' -s "$editor_session_name" -c "$src_cwd" "$helper_cmd"
}

cat > "$helper_file" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

reply_pane="$1"
editor_bin="$2"
msg_file="$3"
orig_file="$4"
tmpdir="$5"
send_mode="$6"
paste_delay="$7"
interrupt_before_paste="$8"
interrupt_after_paste="$9"
interrupt_settle_delay="${10}"
submit_delay="${11}"
cursor_mode="${12}"
payload_builder="${13}"
transport_mode="${14}"
debug_log_file="${15}"
send_file="$tmpdir/send.txt"
post_file="$tmpdir/post.sh"
content_state_file="$tmpdir/content_changed"
content_changed="0"
retain_tmpdir="0"

debug_log() {
  local message="$1"
  {
    printf '%s pid=%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$$" "$message"
  } >> "$debug_log_file" 2>/dev/null || true
}

cleanup() {
  if [[ "$retain_tmpdir" != "1" ]]; then
    debug_log "helper.cleanup tmpdir=$tmpdir retained=0"
    rm -rf "$tmpdir"
  else
    debug_log "helper.cleanup tmpdir=$tmpdir retained=1"
  fi
}

trap cleanup EXIT
debug_log "helper.start transport=$transport_mode send_mode=$send_mode msg_file=$msg_file orig_file=$orig_file tmpdir=$tmpdir"

editor_name="$(basename -- "$editor_bin")"
case "$editor_name" in
  *vim*)
    case "$cursor_mode" in
      end)
        "$editor_bin" +'normal! G$' "$msg_file"
        ;;
      *)
        "$editor_bin" "$msg_file"
        ;;
    esac
    ;;
  *)
    "$editor_bin" "$msg_file"
    ;;
esac

msg_bytes="$(wc -c < "$msg_file" | tr -d '[:space:]')"
orig_bytes="$(wc -c < "$orig_file" | tr -d '[:space:]')"
debug_log "helper.editor_done msg_bytes=$msg_bytes orig_bytes=$orig_bytes"

if [[ -s "$msg_file" ]] && ! cmp -s "$msg_file" "$orig_file"; then
  content_changed="1"
  "$payload_builder" "$orig_file" "$msg_file" "$send_file" "$send_mode"
  send_bytes="$(wc -c < "$send_file" | tr -d '[:space:]')"
  has_droid_edit="0"
  if grep -q '<droid_edit mode="' "$send_file" 2>/dev/null; then
    has_droid_edit="1"
  fi
  debug_log "helper.payload_ready content_changed=1 send_bytes=$send_bytes has_droid_edit=$has_droid_edit"
else
  debug_log "helper.no_change content_changed=0"
fi
printf '%s' "$content_changed" > "$content_state_file"
debug_log "helper.content_state_written path=$content_state_file value=$content_changed"

cat > "$post_file" <<'POST'
#!/usr/bin/env bash
set -euo pipefail

reply_pane="$1"
send_file="$2"
tmpdir="$3"
paste_delay="$4"
content_changed="$5"
interrupt_before_paste="$6"
interrupt_after_paste="$7"
interrupt_settle_delay="$8"
submit_delay="$9"
debug_log_file="${10}"
did_pre_interrupt="0"

debug_log() {
  local message="$1"
  {
    printf '%s pid=%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$$" "$message"
  } >> "$debug_log_file" 2>/dev/null || true
}

capture_reply_pane_snapshot() {
  local lines="$1"
  tmux capture-pane -p -t "$reply_pane" -S "-$lines" 2>/dev/null || return 1
}

log_reply_pane_snapshot() {
  local label="$1"
  local lines="${2:-40}"
  local snapshot=""
  local capture_bytes="0"

  snapshot="$(capture_reply_pane_snapshot "$lines" 2>/dev/null || true)"
  if [[ -z "$snapshot" ]]; then
    debug_log "post.capture label=$label failed=1"
    return 0
  fi

  capture_bytes="$(printf '%s' "$snapshot" | wc -c | tr -d '[:space:]')"
  debug_log "post.capture label=$label bytes=$capture_bytes"
  while IFS= read -r line || [[ -n "$line" ]]; do
    debug_log "post.capture.$label $line"
  done <<< "$snapshot"
}

reply_pane_has_structured_input() {
  local snapshot="$1"
  case "$snapshot" in
    *"> [<droid_edit"*|*"> <droid_edit"*|*"<droid_edit mode="*|*"> [<edited_text"*|*"> <edited_text"*|*"<edited_text>"*)
      return 0
      ;;
  esac
  return 1
}

wait_for_structured_input() {
  local label="$1"
  local attempts="${DROID_VIM_CAPTURE_PROBE_ATTEMPTS:-4}"
  local delay="${DROID_VIM_CAPTURE_PROBE_DELAY:-0.08}"
  local probe_lines="${DROID_VIM_CAPTURE_PROBE_LINES:-8}"
  local fail_lines="${DROID_VIM_CAPTURE_FAIL_LINES:-40}"
  local attempt=1
  local snapshot=""

  while (( attempt <= attempts )); do
    snapshot="$(capture_reply_pane_snapshot "$probe_lines" 2>/dev/null || true)"
    if [[ -n "$snapshot" ]] && reply_pane_has_structured_input "$snapshot"; then
      debug_log "post.probe.ready label=$label attempt=$attempt"
      return 0
    fi
    if (( attempt < attempts )); then
      sleep "$delay"
    fi
    (( attempt += 1 ))
  done

  debug_log "post.probe.failed label=$label attempts=$attempts"
  log_reply_pane_snapshot "${label}_failed" "$fail_lines"
  return 1
}

send_exists="0"
send_bytes="0"
if [[ -f "$send_file" ]]; then
  send_exists="1"
  send_bytes="$(wc -c < "$send_file" | tr -d '[:space:]')"
fi
debug_log "post.start tmpdir=$tmpdir content_changed=$content_changed send_exists=$send_exists send_bytes=$send_bytes"

sleep "$paste_delay"
debug_log "post.after_paste_delay seconds=$paste_delay"

if [[ "$content_changed" == "1" && "$interrupt_before_paste" != "0" ]]; then
  debug_log "post.pre_interrupt action=escape"
  tmux send-keys -t "$reply_pane" Escape
  did_pre_interrupt="1"
  sleep "$interrupt_settle_delay"
  debug_log "post.pre_interrupt_settled seconds=$interrupt_settle_delay"
fi

if [[ "$content_changed" == "1" ]]; then
  send_text="$(cat "$send_file")"
  structured_probe_required="0"
  if [[ "$send_text" == *"<droid_edit"* || "$send_text" == *"<edited_text"* ]]; then
    structured_probe_required="1"
  fi
  if [[ "$send_text" != *$'\n'* && "$send_text" == /* ]]; then
    debug_log "post.send_literal bytes=$send_bytes"
    tmux send-keys -t "$reply_pane" -l "$send_text"
  else
    debug_log "post.paste_buffer bytes=$send_bytes"
    tmux load-buffer "$send_file"
    tmux paste-buffer -p -t "$reply_pane"
  fi
  content_bytes=$(wc -c < "$send_file")
  paste_settle=$(awk "BEGIN { d = 0.10 + ${content_bytes} / 1024 * 0.03; if (d > 3.0) d = 3.0; printf \"%.2f\", d }")
  sleep "$paste_settle"
  debug_log "post.after_paste_settle seconds=$paste_settle"
  if [[ "$structured_probe_required" == "1" ]]; then
    if ! wait_for_structured_input "after_paste"; then
      debug_log "post.submit_skipped reason=missing_structured_input_after_paste"
      rm -rf "$tmpdir"
      exit 0
    fi
  fi
fi

if [[ "$interrupt_after_paste" != "0" ]]; then
  if [[ "$content_changed" == "1" && "$did_pre_interrupt" != "1" ]]; then
    debug_log "post.post_interrupt action=escape reason=changed_without_pre_interrupt"
    tmux send-keys -t "$reply_pane" Escape
  elif [[ "$content_changed" != "1" ]]; then
    debug_log "post.post_interrupt action=escape reason=no_change"
    tmux send-keys -t "$reply_pane" Escape
  fi
fi

if [[ "$content_changed" == "1" ]]; then
  sleep "$submit_delay"
  debug_log "post.submit action=enter seconds=$submit_delay"
  tmux send-keys -t "$reply_pane" Enter
fi
debug_log "post.cleanup tmpdir=$tmpdir"
rm -rf "$tmpdir"
POST
chmod +x "$post_file"
debug_log "helper.post_script_ready path=$post_file transport=$transport_mode"
if [[ "$transport_mode" == "popup" ]]; then
  retain_tmpdir="1"
  debug_log "helper.exit popup=1 tmpdir_retained=1"
  exit 0
fi
trap - EXIT
printf -v post_cmd '%q ' "$post_file" "$reply_pane" "$send_file" "$tmpdir" "$paste_delay" "$content_changed" "$interrupt_before_paste" "$interrupt_after_paste" "$interrupt_settle_delay" "$submit_delay" "$debug_log_file"
debug_log "helper.queue_inline_post content_changed=$content_changed"
tmux run-shell -b "$post_cmd"
EOF
chmod +x "$helper_file"

open_vim_iterm2_window() {
  local editor_session
  local shell_cmd
  editor_session="$(start_editor_session)"

  printf -v shell_cmd 'exec tmux attach-session -t %q' "$editor_session"
  if ! ensure_iterm2_python_api; then
    tmux kill-session -t "$editor_session" >/dev/null 2>&1 || true
    return 1
  fi

  if PYTHONPATH="$iterm2_api_dir" python3 - "$shell_cmd" "$iterm2_window_x" "$iterm2_window_y" "$iterm2_window_width" "$iterm2_window_height" <<'PY' >/dev/null
import sys
import shlex
import iterm2

shell_command = sys.argv[1]
origin_x_arg = sys.argv[2]
origin_y_arg = sys.argv[3]
width = int(sys.argv[4])
height = int(sys.argv[5])

async def main(connection):
    app = await iterm2.async_get_app(connection)
    window = app.current_terminal_window
    if window is None:
        raise RuntimeError("No current iTerm2 window")
    source_frame = await window.async_get_frame()
    origin_x = int(origin_x_arg) if origin_x_arg else round(source_frame.origin.x + (source_frame.size.width - width) / 2)
    origin_y = int(origin_y_arg) if origin_y_arg else round(source_frame.origin.y + (source_frame.size.height - height) / 2)
    command = f"/bin/zsh -lc {shlex.quote(shell_command)}"
    profile = iterm2.profile.LocalWriteOnlyProfile()
    profile.set_use_custom_command(iterm2.profile.Profile.USE_CUSTOM_COMMAND_ENABLED)
    profile.set_command(command)
    profile.set_send_session_ended_alert(False)
    profile.set_close_sessions_on_end(True)
    profile.set_prompt_before_closing(False)
    moved_window = await iterm2.Window.async_create(connection, profile_customizations=profile)
    if moved_window is None:
        raise RuntimeError("Failed to create iTerm2 window")
    frame = iterm2.util.Frame(
        iterm2.util.Point(origin_x, origin_y),
        iterm2.util.Size(width, height),
    )
    await moved_window.async_set_frame(frame)

iterm2.run_until_complete(main, True)
PY
  then
    return 0
  fi

  tmux kill-session -t "$editor_session" >/dev/null 2>&1 || true
  return 1
}

open_vim_ghostty_window() {
  local editor_session
  local shell_cmd
  [[ -d "$ghostty_app" ]] || return 1

  editor_session="$(start_editor_session)"
  printf -v shell_cmd 'exec tmux attach-session -t %q' "$editor_session"

  if open -na "$ghostty_app" --args --quit-after-last-window-closed=true -e /bin/bash -lc "$shell_cmd"; then
    return 0
  fi

  tmux kill-session -t "$editor_session" >/dev/null 2>&1 || true
  return 1
}

open_vim_tmux_popup() {
  local helper_cmd
  local target_client
  local popup_x popup_y popup_w popup_h
  target_client="$(resolve_tmux_target_client)" || return 1
  read -r popup_x popup_y popup_w popup_h < <(resolve_tmux_popup_geometry "$target_client")
  helper_cmd="$(build_helper_cmd)"
  debug_log "popup.open client=$target_client x=$popup_x y=$popup_y w=$popup_w h=$popup_h"
  tmux display-popup -c "$target_client" -t "$src_pane" -d "$src_cwd" -x "$popup_x" -y "$popup_y" -w "$popup_w" -h "$popup_h" -T "$popup_title" -E "$helper_cmd"
  debug_log "popup.closed client=$target_client tmpdir=$tmpdir"
  queue_post_run
}

open_vim_tmux_window() {
  local helper_cmd
  local window_id
  helper_cmd="$(build_helper_cmd)"
  window_id="$(tmux new-window -d -P -F '#{window_id}' -t "$src_session" -c "$src_cwd" -n "$popup_title" "$helper_cmd")"
  tmux select-window -t "$window_id"
}

open_vim_tmux_split() {
  local helper_cmd
  local split_flag
  local before_flag=""
  local pane_id
  helper_cmd="$(build_helper_cmd)"

  case "$split_direction" in
    right)
      split_flag="-h"
      ;;
    left)
      split_flag="-h"
      before_flag="-b"
      ;;
    down)
      split_flag="-v"
      ;;
    up)
      split_flag="-v"
      before_flag="-b"
      ;;
    *)
      echo "unsupported DROID_VIM_SPLIT_DIRECTION: $split_direction" >&2
      return 1
      ;;
  esac

  if [[ -n "$before_flag" ]]; then
    pane_id="$(tmux split-window "$split_flag" "$before_flag" -P -F '#{pane_id}' -t "$src_pane" -c "$src_cwd" "$helper_cmd")"
  else
    pane_id="$(tmux split-window "$split_flag" -P -F '#{pane_id}' -t "$src_pane" -c "$src_cwd" "$helper_cmd")"
  fi
  tmux select-pane -t "$pane_id"
}

open_vim_window() {
  case "$transport" in
    auto)
      if tmux_client_is_iterm2; then
        open_vim_iterm2_window && return 0
      fi
      if tmux_client_is_ghostty; then
        open_vim_tmux_split && return 0
      fi
      open_vim_tmux_window
      ;;
    iterm2)
      open_vim_iterm2_window && return 0
      tmux_supports_popup && open_vim_tmux_popup && return 0
      open_vim_tmux_window
      ;;
    ghostty)
      open_vim_ghostty_window && return 0
      open_vim_tmux_window
      ;;
    popup)
      tmux_supports_popup && open_vim_tmux_popup && return 0
      open_vim_tmux_window
      ;;
    split)
      open_vim_tmux_split && return 0
      open_vim_tmux_window
      ;;
    window)
      open_vim_tmux_window
      ;;
    *)
      echo "unsupported DROID_VIM_TRANSPORT: $transport" >&2
      exit 1
      ;;
  esac
}

# Parse offset from args: /cvim -1 → offset=1, /cvim -2 → offset=2, /cvim → offset=0
vim_offset=0
remaining_args=()
for arg in "$@"; do
  if [[ "$arg" =~ ^-([0-9]+)$ ]]; then
    vim_offset="${BASH_REMATCH[1]}"
  else
    remaining_args+=("$arg")
  fi
done
set -- "${remaining_args[@]+"${remaining_args[@]}"}"
printf '%s\n' "$vim_offset" > "$tmpdir/offset"

if [[ $# -gt 0 ]]; then
  printf '%s\n' "$*" > "$msg_file"
  debug_log "seed.args bytes=$(wc -c < "$msg_file" | tr -d '[:space:]')"
elif [[ "$seed_mode" == "session" ]]; then
  transcript_path=""
  if [[ -n "$src_pane_tty_key" ]]; then
    transcript_path="$("$session_helper" "$session_map_file" "$src_cwd" "" "$src_pane_tty_key" "")"
  fi
  if [[ -n "$transcript_path" && -f "$transcript_path" ]]; then
    "$seed_helper" "$src_cwd" "$msg_file" "$transcript_path" "$vim_offset"
    debug_log "seed.session transcript_path=$transcript_path offset=$vim_offset bytes=$(wc -c < "$msg_file" | tr -d '[:space:]')"
  else
  droid_pid=""
  droid_tty=""
  droid_args=""
  if info="$(resolve_current_droid_process_info 2>/dev/null)" && [[ -n "$info" ]]; then
    IFS=$'\t' read -r droid_pid droid_tty droid_args <<<"$info"
  fi
  capture_session_seed_to_file "$src_cwd" "$msg_file" "$droid_pid" "$droid_tty" "$droid_args" "$vim_offset"
  debug_log "seed.capture pid=${droid_pid:-none} tty=${droid_tty:-none} offset=$vim_offset bytes=$(wc -c < "$msg_file" | tr -d '[:space:]')"
  fi
else
  : > "$msg_file"
  debug_log "seed.blank"
fi

cp "$msg_file" "$orig_file"
debug_log "command.open_window msg_bytes=$(wc -c < "$msg_file" | tr -d '[:space:]') orig_bytes=$(wc -c < "$orig_file" | tr -d '[:space:]') debug_log=$debug_log_file"
open_vim_window
