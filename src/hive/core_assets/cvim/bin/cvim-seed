#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path

from _cvim_shared import write_seed


def main() -> int:
    args = sys.argv[1:]

    # 2-arg: cwd dst
    # 3-arg: cwd dst preferred_transcript
    # 4-arg: cwd dst preferred_transcript offset
    if len(args) in {2, 3, 4}:
        cwd = args[0]
        dst = Path(args[1])
        preferred = Path(args[2]) if len(args) >= 3 and args[2] else None
        offset = int(args[3]) if len(args) >= 4 and args[3] else 0
        write_seed(cwd, dst, preferred, offset=offset)
        return 0

    raise SystemExit("usage: cvim-seed <cwd> <dst> [preferred] [offset]")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
