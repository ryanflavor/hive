#!/usr/bin/env bash
set -euo pipefail

mode="${1:-cvim}"
shift || true

case "$mode" in
  cvim)
    seed_mode="${CVIM_SEED_MODE:-session}"
    output_mode="${CVIM_OUTPUT_MODE:-diff}"
    cursor_mode="${CVIM_CURSOR_MODE:-start}"
    popup_title="hive-cvim"
    ;;
  vim)
    seed_mode="${CVIM_SEED_MODE:-blank}"
    output_mode="${CVIM_OUTPUT_MODE:-text}"
    cursor_mode="${CVIM_CURSOR_MODE:-end}"
    popup_title="hive-vim"
    ;;
  *)
    echo "cvim-command: unknown mode '$mode' (expected cvim or vim)" >&2
    exit 1
    ;;
esac

case "$seed_mode" in session|blank) ;; *) echo "cvim-command: invalid CVIM_SEED_MODE '$seed_mode' (expected session|blank)" >&2; exit 1 ;; esac
case "$output_mode" in diff|text) ;; *) echo "cvim-command: invalid CVIM_OUTPUT_MODE '$output_mode' (expected diff|text)" >&2; exit 1 ;; esac
case "$cursor_mode" in start|end) ;; *) echo "cvim-command: invalid CVIM_CURSOR_MODE '$cursor_mode' (expected start|end)" >&2; exit 1 ;; esac

if [[ -z "${TMUX:-}" ]]; then
  echo "/$mode requires tmux." >&2
  exit 1
fi

editor_bin="${CVIM_EDITOR:-vim}"
if ! command -v "$editor_bin" >/dev/null 2>&1; then
  echo "editor not found: $editor_bin" >&2
  exit 1
fi

reply_pane="${TMUX_PANE:-}"
if [[ -n "$reply_pane" ]] && ! tmux display-message -p -t "$reply_pane" '#{pane_id}' >/dev/null 2>&1; then
  reply_pane=""
fi
src_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
if [[ -z "$src_pane" ]]; then
  src_pane="$reply_pane"
fi
if [[ -z "$src_pane" ]]; then
  echo "/$mode could not resolve current tmux pane." >&2
  exit 1
fi
if [[ -z "$reply_pane" ]]; then
  reply_pane="$src_pane"
fi
src_cwd="$(tmux display-message -p -t "$src_pane" '#{pane_current_path}')"
src_session="$(tmux display-message -p -t "$src_pane" '#{session_id}')"
src_window="$(tmux display-message -p -t "$src_pane" '#{window_id}')"
src_pane_pid="$(tmux display-message -p -t "$src_pane" '#{pane_pid}')"
src_pane_tty="$(tmux display-message -p -t "$src_pane" '#{pane_tty}')"
src_client_tty="$(tmux display-message -p -t "$src_pane" '#{client_tty}')"
src_client_pid="$(tmux display-message -p -t "$src_pane" '#{client_pid}')"
src_workspace="$(tmux display-message -p -t "$src_pane" '#{@hive-workspace}' 2>/dev/null || true)"
script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
resources_dir="$(CDPATH= cd -- "$script_dir/../resources" && pwd 2>/dev/null || true)"
seed_helper="$script_dir/cvim-seed"
session_helper="$script_dir/cvim-session"
list_helper="$script_dir/cvim-list"
payload_builder="$script_dir/cvim-payload"
menu_vim_template="$resources_dir/menu.vim"
tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/cvim.XXXXXX")"
msg_file="$tmpdir/message.md"
orig_file="$tmpdir/original.md"
helper_file="$tmpdir/run.sh"
debug_lib="$tmpdir/debug.sh"
if [[ -n "$src_workspace" ]]; then
  debug_root="$src_workspace/run/cvim"
else
  debug_root="${XDG_CACHE_HOME:-$HOME/.cache}/hive/cvim"
fi
mkdir -p "$debug_root" >/dev/null 2>&1 || true
find "$debug_root" -type f \( -name '*.jsonl' -o -name 'cvim.*' \) -mtime +7 -exec rm -f {} + >/dev/null 2>&1 || true
debug_run_id="$(date -u '+%Y%m%dT%H%M%SZ').$$.${RANDOM:-0}"
debug_log_file="$debug_root/$debug_run_id.jsonl"
: > "$debug_log_file" 2>/dev/null || true
printf '%s\n' "$debug_log_file" > "$debug_root/latest" 2>/dev/null || true

cat > "$debug_lib" <<'EOF'
cvim_json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\t'/\\t}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\n'/\\n}"
  printf '%s' "$value"
}

cvim_debug_log() {
  local log_file="$1"
  local workspace="$2"
  local run_id="$3"
  local pid="$4"
  local raw="$5"
  local event=""
  local message=""
  local ts=""

  case "$raw" in
    *" "*)
      event="${raw%% *}"
      message="${raw#* }"
      ;;
    *)
      event="$raw"
      message=""
      ;;
  esac
  if [[ -n "${EPOCHREALTIME:-}" ]]; then
    ts="$(TZ=UTC printf '%(%Y-%m-%dT%H:%M:%S)T.%sZ' "${EPOCHREALTIME%.*}" "${EPOCHREALTIME#*.}")"
    ts="${ts:0:23}Z"
  else
    ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  fi
  workspace="${workspace:-<global>}"
  printf '{"ts":"%s","pid":%s,"component":"cvim","workspace":"%s","runId":"%s","event":"%s","message":"%s"}\n' \
    "$(cvim_json_escape "$ts")" \
    "$pid" \
    "$(cvim_json_escape "$workspace")" \
    "$(cvim_json_escape "$run_id")" \
    "$(cvim_json_escape "$event")" \
    "$(cvim_json_escape "$message")" \
    >> "$log_file" 2>/dev/null || true
}
EOF
. "$debug_lib"

paste_delay_default="${CVIM_PASTE_DELAY:-0.60}"
interrupt_before_paste_default="${CVIM_INTERRUPT_BEFORE_PASTE:-1}"
interrupt_after_paste_default="${CVIM_INTERRUPT_AFTER_PASTE:-1}"
interrupt_settle_delay_default="${CVIM_INTERRUPT_SETTLE_DELAY:-0.08}"
submit_delay_default="${CVIM_SUBMIT_DELAY:-0.03}"
clear_input_before_paste_default="${CVIM_CLEAR_INPUT_BEFORE_PASTE:-auto}"

debug_log() {
  local message="$1"
  cvim_debug_log "$debug_log_file" "$src_workspace" "$debug_run_id" "$$" "$message"
}

resolve_current_droid_process_info() {
  python3 - "$src_pane_pid" "$src_pane_tty" <<'PY'
import subprocess
import sys

root = int(sys.argv[1])
pane_tty = sys.argv[2]
out = subprocess.check_output(['ps', '-axo', 'pid=,ppid=,tty=,comm=,args='], text=True)
rows = []
for line in out.splitlines():
    parts = line.strip().split(None, 4)
    if len(parts) < 5:
        continue
    pid, ppid, tty, comm, args = int(parts[0]), int(parts[1]), parts[2], parts[3], parts[4]
    rows.append((pid, ppid, tty, comm, args))

by_ppid = {}
for row in rows:
    by_ppid.setdefault(row[1], []).append(row)

best = None
stack = [root]
seen = set()
while stack:
    pid = stack.pop()
    if pid in seen:
        continue
    seen.add(pid)
    for child in by_ppid.get(pid, []):
        child_pid, _, tty, comm, args = child
        if comm == 'droid':
            if best is None or tty == pane_tty:
                best = child
                if tty == pane_tty:
                    print(f'{child_pid}\t{tty}\t{args}')
                    raise SystemExit(0)
        stack.append(child_pid)

if best is not None:
    print(f'{best[0]}\t{best[2]}\t{best[4]}')
PY
}

detect_src_profile() {
  python3 - "$src_pane" <<'PY'
import importlib
import sys

agent_cli = importlib.import_module("hive.agent_cli")
profile = agent_cli.detect_profile_for_pane(sys.argv[1])
if profile is not None:
    print(profile.name)
PY
}

src_profile="$(detect_src_profile 2>/dev/null || true)"
if [[ -z "$src_profile" ]]; then
  src_profile="unknown"
fi

case "$(printf '%s' "$clear_input_before_paste_default" | tr '[:upper:]' '[:lower:]')" in
  auto)
    if [[ "$src_profile" == "droid" ]]; then
      clear_input_before_paste_default="0"
    else
      clear_input_before_paste_default="1"
    fi
    ;;
  1|true|yes|on)
    clear_input_before_paste_default="1"
    ;;
  0|false|no|off)
    clear_input_before_paste_default="0"
    ;;
  *)
    if [[ "$src_profile" == "droid" ]]; then
      clear_input_before_paste_default="0"
    else
      clear_input_before_paste_default="1"
    fi
    ;;
esac

build_helper_cmd() {
  printf '%q ' "$helper_file" "$reply_pane" "$editor_bin" "$msg_file" "$orig_file" "$tmpdir" "$output_mode" "$paste_delay_default" "$interrupt_before_paste_default" "$interrupt_after_paste_default" "$interrupt_settle_delay_default" "$submit_delay_default" "$clear_input_before_paste_default" "$cursor_mode" "$payload_builder" "$src_profile" "$debug_log_file" "$src_workspace" "$debug_run_id" "$debug_lib"
}

queue_post_run() {
  local content_state_file="$tmpdir/content_changed"
  local send_file="$tmpdir/send.txt"
  local post_file="$tmpdir/post.sh"
  local content_changed="0"
  local send_exists="0"
  local send_bytes="0"

  if [[ -f "$content_state_file" ]]; then
    content_changed="$(cat "$content_state_file" 2>/dev/null || printf '0')"
  fi

  if [[ ! -f "$post_file" ]]; then
    debug_log "queue_post_run.skip post_file=missing tmpdir=$tmpdir content_changed=$content_changed"
    rm -rf "$tmpdir"
    return 0
  fi

  if [[ -f "$send_file" ]]; then
    send_exists="1"
    send_bytes="$(wc -c < "$send_file" | tr -d '[:space:]')"
  fi

  debug_log "queue_post_run.enqueue tmpdir=$tmpdir content_changed=$content_changed send_exists=$send_exists send_bytes=$send_bytes"
  printf -v post_cmd '%q ' "$post_file" "$reply_pane" "$send_file" "$tmpdir" "$paste_delay_default" "$content_changed" "$interrupt_before_paste_default" "$interrupt_after_paste_default" "$interrupt_settle_delay_default" "$submit_delay_default" "$clear_input_before_paste_default" "$src_profile" "$debug_log_file" "$src_workspace" "$debug_run_id" "$debug_lib"
  tmux run-shell -b "$post_cmd"
}

debug_log "command.start mode=$mode seed_mode=$seed_mode output_mode=$output_mode src_pane=$src_pane reply_pane=$reply_pane profile=$src_profile clear_input=$clear_input_before_paste_default cwd=$src_cwd tmpdir=$tmpdir"

resolve_tmux_target_client() {
  local client_tty
  if [[ -n "$src_client_tty" ]]; then
    printf '%s\n' "$src_client_tty"
    return 0
  fi

  client_tty="$(tmux list-clients -t "$src_session" -F '#{client_activity} #{client_tty}' 2>/dev/null | sort -rn | awk 'NF >= 2 { print $2; exit }')"
  [[ -n "$client_tty" ]] || return 1
  printf '%s\n' "$client_tty"
}

# Returned y is the popup *bottom* edge row (what tmux's numeric `display-popup -y`
# wants). tmux internally does `top = y - height`, so "popup top = region_y" means
# we must return `region_y + height`.
fit_popup_to_region() {
  local region_x="$1"
  local region_y="$2"
  local region_w="$3"
  local region_h="$4"
  local align="$5"
  local width="$region_w"
  local height="$region_h"
  local x y

  case "$align" in
    right)
      x=$(( region_x + region_w - width ))
      y=$(( region_y + (region_h + height) / 2 ))
      ;;
    left)
      x="$region_x"
      y=$(( region_y + (region_h + height) / 2 ))
      ;;
    bottom)
      x=$(( region_x + (region_w - width) / 2 ))
      y=$(( region_y + region_h ))
      ;;
    top)
      x=$(( region_x + (region_w - width) / 2 ))
      y=$(( region_y + height ))
      ;;
    *)
      x=$(( region_x + (region_w - width) / 2 ))
      y=$(( region_y + (region_h + height) / 2 ))
      ;;
  esac

  printf '%s %s %s %s\n' "$x" "$y" "$width" "$height"
}

resolve_tmux_popup_geometry() {
  local target_client="$1"
  local client_width client_height
  local popup_x popup_y popup_w popup_h
  local pane_id pane_left pane_top pane_width pane_height
  local pane_count
  local pane_lines
  local src_left=0 src_top=0 src_width=0 src_height=0
  local src_center_x src_center_y
  local bb_left bb_top bb_right bb_bottom
  local selected_side
  local bottom_found=0
  local top_found=0

  client_width="$(tmux display-message -p -c "$target_client" '#{client_width}')"
  client_height="$(tmux display-message -p -c "$target_client" '#{client_height}')"
  pane_lines="$(tmux list-panes -t "$src_window" -F '#{pane_id} #{pane_left} #{pane_top} #{pane_width} #{pane_height}' 2>/dev/null || true)"
  pane_count="$(printf '%s\n' "$pane_lines" | awk 'NF >= 5 { count++ } END { print count + 0 }')"

  if (( pane_count <= 1 )); then
    local region_x=$(( client_width / 2 ))
    local region_w=$(( client_width - region_x ))
    read -r popup_x popup_y popup_w popup_h < <(
      fit_popup_to_region "$region_x" 0 "$region_w" "$client_height" "right"
    )
    printf '%s %s %s %s\n' "$popup_x" "$popup_y" "$popup_w" "$popup_h"
    return 0
  fi

  local -a pane_ids=()
  local -a pane_lefts=()
  local -a pane_tops=()
  local -a pane_widths=()
  local -a pane_heights=()
  local i=0

  while read -r pane_id pane_left pane_top pane_width pane_height; do
    [[ -n "$pane_id" ]] || continue
    pane_ids+=("$pane_id")
    pane_lefts+=("$pane_left")
    pane_tops+=("$pane_top")
    pane_widths+=("$pane_width")
    pane_heights+=("$pane_height")
    if [[ "$pane_id" == "$src_pane" ]]; then
      src_left="$pane_left"
      src_top="$pane_top"
      src_width="$pane_width"
      src_height="$pane_height"
    fi
    (( i += 1 ))
  done <<< "$pane_lines"

  local total=${#pane_ids[@]}
  local right_found=0
  local left_found=0
  local pane_center_x pane_center_y

  src_center_x=$(( src_left + src_width / 2 ))
  src_center_y=$(( src_top + src_height / 2 ))

  for (( i=0; i<total; i++ )); do
    [[ "${pane_ids[i]}" == "$src_pane" ]] && continue
    pane_center_x=$(( pane_lefts[i] + pane_widths[i] / 2 ))
    pane_center_y=$(( pane_tops[i] + pane_heights[i] / 2 ))
    if (( pane_center_x > src_center_x )); then
      right_found=1
    elif (( pane_center_x < src_center_x )); then
      left_found=1
    fi
    if (( pane_center_y > src_center_y )); then
      bottom_found=1
    elif (( pane_center_y < src_center_y )); then
      top_found=1
    fi
  done

  selected_side=""
  if (( right_found )); then
    selected_side="right"
  elif (( left_found )); then
    selected_side="left"
  elif (( bottom_found )); then
    selected_side="bottom"
  elif (( top_found )); then
    selected_side="top"
  fi

  bb_left=999999
  bb_top=999999
  bb_right=0
  bb_bottom=0
  local found=0

  for (( i=0; i<total; i++ )); do
    [[ "${pane_ids[i]}" == "$src_pane" ]] && continue
    pane_center_x=$(( pane_lefts[i] + pane_widths[i] / 2 ))
    pane_center_y=$(( pane_tops[i] + pane_heights[i] / 2 ))
    case "$selected_side" in
      right)
        (( pane_center_x > src_center_x )) || continue
        ;;
      left)
        (( pane_center_x < src_center_x )) || continue
        ;;
      bottom)
        (( pane_center_y > src_center_y )) || continue
        ;;
      top)
        (( pane_center_y < src_center_y )) || continue
        ;;
      *)
        continue
        ;;
    esac
    found=1
    local r=$(( pane_lefts[i] + pane_widths[i] ))
    local b=$(( pane_tops[i] + pane_heights[i] ))
    (( pane_lefts[i] < bb_left )) && bb_left=${pane_lefts[i]}
    (( pane_tops[i] < bb_top )) && bb_top=${pane_tops[i]}
    (( r > bb_right )) && bb_right=$r
    (( b > bb_bottom )) && bb_bottom=$b
  done

  if (( found )); then
    read -r popup_x popup_y popup_w popup_h < <(
      fit_popup_to_region \
        "$bb_left" "$bb_top" "$(( bb_right - bb_left ))" "$(( bb_bottom - bb_top ))" \
        "$selected_side"
    )
  else
    local region_x=$(( client_width / 2 ))
    local region_w=$(( client_width - region_x ))
    read -r popup_x popup_y popup_w popup_h < <(
      fit_popup_to_region "$region_x" 0 "$region_w" "$client_height" "right"
    )
  fi

  printf '%s %s %s %s\n' "$popup_x" "$popup_y" "$popup_w" "$popup_h"
}

cat > "$helper_file" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

reply_pane="$1"
editor_bin="$2"
msg_file="$3"
orig_file="$4"
tmpdir="$5"
send_mode="$6"
paste_delay="$7"
interrupt_before_paste="$8"
interrupt_after_paste="$9"
interrupt_settle_delay="${10}"
submit_delay="${11}"
clear_input_before_paste="${12}"
cursor_mode="${13}"
payload_builder="${14}"
reply_profile="${15}"
debug_log_file="${16}"
debug_workspace="${17}"
debug_run_id="${18}"
debug_lib="${19}"
send_file="$tmpdir/send.txt"
post_file="$tmpdir/post.sh"
content_state_file="$tmpdir/content_changed"
content_changed="0"
retain_tmpdir="0"
. "$debug_lib"

debug_log() {
  local message="$1"
  cvim_debug_log "$debug_log_file" "$debug_workspace" "$debug_run_id" "$$" "$message"
}

cleanup() {
  if [[ "$retain_tmpdir" != "1" ]]; then
    debug_log "helper.cleanup tmpdir=$tmpdir retained=0"
    rm -rf "$tmpdir"
  else
    debug_log "helper.cleanup tmpdir=$tmpdir retained=1"
  fi
}

trap cleanup EXIT
debug_log "helper.start send_mode=$send_mode msg_file=$msg_file orig_file=$orig_file tmpdir=$tmpdir"

editor_name="$(basename -- "$editor_bin")"
menu_enabled=0
if [[ -f "$tmpdir/menu.vim" && -f "$tmpdir/menu.json" ]]; then
  export CVIM_MENU_JSON="$tmpdir/menu.json"
  export CVIM_SEEDS_DIR="$tmpdir/seeds"
  export CVIM_MSG_FILE="$msg_file"
  export CVIM_ORIG_FILE="$orig_file"
  export CVIM_OFFSET_FILE="$tmpdir/offset"
  export CVIM_MENU_SELECTED_FILE="$tmpdir/menu_selected"
  menu_enabled=1
  debug_log "helper.menu_mode enabled menu_json=$CVIM_MENU_JSON seeds=$CVIM_SEEDS_DIR"
fi

case "$editor_name" in
  *vim*)
    case "$cursor_mode" in
      end)
        if [[ "$menu_enabled" == "1" ]]; then
          "$editor_bin" -S "$tmpdir/menu.vim" +'normal! G$' "$msg_file"
        else
          "$editor_bin" +'normal! G$' "$msg_file"
        fi
        ;;
      *)
        if [[ "$menu_enabled" == "1" ]]; then
          "$editor_bin" -S "$tmpdir/menu.vim" "$msg_file"
        else
          "$editor_bin" "$msg_file"
        fi
        ;;
    esac
    ;;
  *)
    "$editor_bin" "$msg_file"
    ;;
esac

msg_bytes="$(wc -c < "$msg_file" | tr -d '[:space:]')"
orig_bytes="$(wc -c < "$orig_file" | tr -d '[:space:]')"
debug_log "helper.editor_done msg_bytes=$msg_bytes orig_bytes=$orig_bytes"

if [[ -s "$msg_file" ]] && ! cmp -s "$msg_file" "$orig_file"; then
  content_changed="1"
  python3 "$payload_builder" "$orig_file" "$msg_file" "$send_file" "$send_mode"
  send_bytes="$(wc -c < "$send_file" | tr -d '[:space:]')"
  has_comment="0"
  if grep -q '^<comment on="' "$send_file" 2>/dev/null; then
    has_comment="1"
  fi
  debug_log "helper.payload_ready content_changed=1 send_bytes=$send_bytes has_comment=$has_comment"
else
  debug_log "helper.no_change content_changed=0"
fi
printf '%s' "$content_changed" > "$content_state_file"
debug_log "helper.content_state_written path=$content_state_file value=$content_changed"

cat > "$post_file" <<'POST'
#!/usr/bin/env bash
set -euo pipefail

reply_pane="$1"
send_file="$2"
tmpdir="$3"
paste_delay="$4"
content_changed="$5"
interrupt_before_paste="$6"
interrupt_after_paste="$7"
interrupt_settle_delay="$8"
submit_delay="$9"
clear_input_before_paste="${10}"
reply_profile="${11}"
debug_log_file="${12}"
debug_workspace="${13}"
debug_run_id="${14}"
debug_lib="${15}"
did_pre_interrupt="0"
. "$debug_lib"

debug_log() {
  local message="$1"
  cvim_debug_log "$debug_log_file" "$debug_workspace" "$debug_run_id" "$$" "$message"
}

capture_reply_pane_snapshot() {
  local lines="$1"
  tmux capture-pane -p -t "$reply_pane" -S "-$lines" 2>/dev/null || return 1
}

log_reply_pane_snapshot() {
  local label="$1"
  local lines="${2:-40}"
  local snapshot=""
  local capture_bytes="0"

  snapshot="$(capture_reply_pane_snapshot "$lines" 2>/dev/null || true)"
  if [[ -z "$snapshot" ]]; then
    debug_log "post.capture label=$label failed=1"
    return 0
  fi

  capture_bytes="$(printf '%s' "$snapshot" | wc -c | tr -d '[:space:]')"
  debug_log "post.capture label=$label bytes=$capture_bytes"
  while IFS= read -r line || [[ -n "$line" ]]; do
    debug_log "post.capture.$label $line"
  done <<< "$snapshot"
}

clear_reply_input() {
  if [[ "$clear_input_before_paste" != "1" ]]; then
    return 0
  fi
  debug_log "post.clear_input action=ctrl-u"
  tmux send-keys -t "$reply_pane" C-u
  sleep "$interrupt_settle_delay"
  debug_log "post.clear_input_settled seconds=$interrupt_settle_delay"
}

wait_for_idle_input() {
  if [[ "$reply_profile" != "droid" ]]; then
    return 0
  fi
  local settle="${CVIM_IDLE_SETTLE:-0.30}"
  debug_log "post.idle_settle seconds=$settle"
  sleep "$settle"
}

reply_pane_ready_matcher() {
  local snapshot="$1"
  local profile="${2:-unknown}"
  case "$snapshot" in
    *"> [<comment on="*|*"> <comment on="*|*"<comment on=\""*)
      printf 'structured_payload\n'
      return 0
      ;;
  esac
  if [[ "$profile" == "claude" ]]; then
    case "$snapshot" in
      *"[Pasted text #"*)
        printf 'claude_pasted_placeholder\n'
        return 0
        ;;
    esac
  fi
  return 1
}

wait_for_submit_ready_input() {
  local label="$1"
  local attempts="${CVIM_CAPTURE_PROBE_ATTEMPTS:-4}"
  local delay="${CVIM_CAPTURE_PROBE_DELAY:-0.08}"
  local probe_lines="${CVIM_CAPTURE_PROBE_LINES:-8}"
  local fail_lines="${CVIM_CAPTURE_FAIL_LINES:-40}"
  local attempt=1
  local snapshot=""
  local matcher=""

  while (( attempt <= attempts )); do
    snapshot="$(capture_reply_pane_snapshot "$probe_lines" 2>/dev/null || true)"
    matcher="$(reply_pane_ready_matcher "$snapshot" "$reply_profile" 2>/dev/null || true)"
    if [[ -n "$snapshot" && -n "$matcher" ]]; then
      debug_log "post.probe.ready label=$label attempt=$attempt profile=$reply_profile matcher=$matcher"
      return 0
    fi
    if (( attempt < attempts )); then
      sleep "$delay"
    fi
    (( attempt += 1 ))
  done

  debug_log "post.probe.failed label=$label attempts=$attempts profile=$reply_profile"
  log_reply_pane_snapshot "${label}_failed" "$fail_lines"
  return 1
}

send_exists="0"
send_bytes="0"
if [[ -f "$send_file" ]]; then
  send_exists="1"
  send_bytes="$(wc -c < "$send_file" | tr -d '[:space:]')"
fi
debug_log "post.start tmpdir=$tmpdir content_changed=$content_changed send_exists=$send_exists send_bytes=$send_bytes"

if [[ "$reply_profile" == "droid" && "$content_changed" == "1" ]]; then
  debug_log "post.droid_fast_path start"
  debug_log "post.pre_interrupt action=escape"
  tmux send-keys -t "$reply_pane" Escape
  did_pre_interrupt="1"
  wait_for_idle_input
  debug_log "post.paste_buffer bytes=$send_bytes"
  tmux load-buffer "$send_file"
  tmux paste-buffer -p -t "$reply_pane"
  if ! wait_for_submit_ready_input "after_paste"; then
    debug_log "post.submit_skipped reason=missing_submit_ready_input_after_paste"
    rm -rf "$tmpdir"
    exit 0
  fi
else
  sleep "$paste_delay"
  debug_log "post.after_paste_delay seconds=$paste_delay"

  if [[ "$content_changed" == "1" && "$interrupt_before_paste" != "0" ]]; then
    debug_log "post.pre_interrupt action=escape"
    tmux send-keys -t "$reply_pane" Escape
    did_pre_interrupt="1"
    sleep "$interrupt_settle_delay"
    debug_log "post.pre_interrupt_settled seconds=$interrupt_settle_delay"
  fi

  clear_reply_input

  if [[ "$content_changed" == "1" ]]; then
    send_text="$(cat "$send_file")"
    submit_probe_required="0"
    if [[ "$send_text" == "<comment on=\""* ]]; then
      submit_probe_required="1"
    fi
    if [[ "$send_text" != *$'\n'* && "$send_text" == /* ]]; then
      debug_log "post.send_literal bytes=$send_bytes"
      tmux send-keys -t "$reply_pane" -l "$send_text"
    else
      debug_log "post.paste_buffer bytes=$send_bytes"
      tmux load-buffer "$send_file"
      tmux paste-buffer -p -t "$reply_pane"
    fi
    content_bytes=$(wc -c < "$send_file")
    paste_settle=$(awk "BEGIN { d = 0.10 + ${content_bytes} / 1024 * 0.03; if (d > 3.0) d = 3.0; printf \"%.2f\", d }")
    sleep "$paste_settle"
    debug_log "post.after_paste_settle seconds=$paste_settle"
    if [[ "$submit_probe_required" == "1" ]]; then
      if ! wait_for_submit_ready_input "after_paste"; then
        debug_log "post.submit_skipped reason=missing_submit_ready_input_after_paste"
        rm -rf "$tmpdir"
        exit 0
      fi
    fi
  fi
fi

if [[ "$interrupt_after_paste" != "0" ]]; then
  if [[ "$content_changed" == "1" && "$did_pre_interrupt" != "1" ]]; then
    debug_log "post.post_interrupt action=escape reason=changed_without_pre_interrupt"
    tmux send-keys -t "$reply_pane" Escape
  elif [[ "$content_changed" != "1" ]]; then
    debug_log "post.post_interrupt action=escape reason=no_change"
    tmux send-keys -t "$reply_pane" Escape
  fi
fi

if [[ "$content_changed" == "1" ]]; then
  sleep "$submit_delay"
  debug_log "post.submit action=enter seconds=$submit_delay"
  tmux send-keys -t "$reply_pane" Enter
fi
debug_log "post.cleanup tmpdir=$tmpdir"
rm -rf "$tmpdir"
POST
chmod +x "$post_file"
debug_log "helper.post_script_ready path=$post_file"
retain_tmpdir="1"
debug_log "helper.exit popup=1 tmpdir_retained=1"
exit 0
EOF
chmod +x "$helper_file"

open_vim_tmux_popup() {
  local helper_cmd
  local target_client
  local popup_x popup_y popup_w popup_h
  target_client="$(resolve_tmux_target_client)" || return 1
  read -r popup_x popup_y popup_w popup_h < <(resolve_tmux_popup_geometry "$target_client")
  helper_cmd="$(build_helper_cmd)"
  debug_log "popup.open client=$target_client x=$popup_x y=$popup_y w=$popup_w h=$popup_h"
  tmux display-popup -c "$target_client" -t "$src_pane" -d "$src_cwd" -x "$popup_x" -y "$popup_y" -w "$popup_w" -h "$popup_h" -T "$popup_title" -E "$helper_cmd"
  debug_log "popup.closed client=$target_client tmpdir=$tmpdir"
  queue_post_run
}

# Parse offset from args: /cvim -1 → offset=1, /cvim -2 → offset=2, /cvim → offset=0
vim_offset=0
remaining_args=()
for arg in "$@"; do
  if [[ "$arg" =~ ^-([0-9]+)$ ]]; then
    vim_offset="${BASH_REMATCH[1]}"
  else
    remaining_args+=("$arg")
  fi
done
set -- "${remaining_args[@]+"${remaining_args[@]}"}"
printf '%s\n' "$vim_offset" > "$tmpdir/offset"

menu_mode=0
maybe_prepare_menu() {
  # Called with a resolved transcript path. When no explicit offset / args
  # were given, prepares the popup-menu assets in $tmpdir so the vim helper
  # can launch the picker. The caller is responsible for transcript
  # detection/fallback; this function only decides whether to seed a single
  # message or to stage the menu.
  local transcript_path="$1"
  if [[ $# -gt 1 && "$2" -ne 0 ]]; then
    python3 "$seed_helper" "$src_cwd" "$msg_file" "$transcript_path" "$2"
    return 0
  fi
  if [[ -z "$menu_vim_template" || ! -f "$menu_vim_template" || ! -f "$list_helper" ]]; then
    python3 "$seed_helper" "$src_cwd" "$msg_file" "$transcript_path" "0"
    return 0
  fi
  if ! python3 "$list_helper" "$transcript_path" "$tmpdir/seeds" "$tmpdir/menu.json" >/dev/null 2>&1; then
    python3 "$seed_helper" "$src_cwd" "$msg_file" "$transcript_path" "0"
    return 0
  fi
  local entry_count
  entry_count="$(python3 -c 'import json,sys; print(len(json.load(open(sys.argv[1]))))' "$tmpdir/menu.json" 2>/dev/null || printf '0')"
  if [[ "$entry_count" == "0" ]]; then
    python3 "$seed_helper" "$src_cwd" "$msg_file" "$transcript_path" "0"
    return 0
  fi
  cp "$menu_vim_template" "$tmpdir/menu.vim"
  # Seed the buffer with the newest assistant message as a fallback. If the
  # vim popup_menu fails to render (e.g. nested tmux popup + alt-screen
  # parents), the user still sees the most-recent message instead of an
  # empty buffer. When popup_menu does come up and the user picks an entry,
  # menu.vim's HiveCvimMenuPick rewrites both msg_file and orig_file before
  # `:edit!`, so this seed is harmlessly overwritten.
  python3 "$seed_helper" "$src_cwd" "$msg_file" "$transcript_path" "0" \
    || : > "$msg_file"
  menu_mode=1
  debug_log "seed.menu transcript_path=$transcript_path entries=$entry_count"
}

if [[ $# -gt 0 ]]; then
  printf '%s\n' "$*" > "$msg_file"
  debug_log "seed.args bytes=$(wc -c < "$msg_file" | tr -d '[:space:]')"
elif [[ "$seed_mode" == "session" ]]; then
  transcript_path="$(python3 "$session_helper" "$src_cwd" "" "$src_pane" 2>/dev/null || true)"
  if [[ -n "$transcript_path" && -f "$transcript_path" ]]; then
    printf '%s\n' "$transcript_path" > "$tmpdir/transcript_path"
    maybe_prepare_menu "$transcript_path" "$vim_offset"
    debug_log "seed.session transcript_path=$transcript_path offset=$vim_offset menu_mode=$menu_mode bytes=$(wc -c < "$msg_file" | tr -d '[:space:]')"
  elif [[ "$src_profile" == "droid" || "$src_profile" == "unknown" ]]; then
    droid_pid=""
    droid_tty=""
    droid_args=""
    if info="$(resolve_current_droid_process_info 2>/dev/null)" && [[ -n "$info" ]]; then
      IFS=$'\t' read -r droid_pid droid_tty droid_args <<<"$info"
    fi
    transcript_path="$(python3 "$session_helper" "$src_cwd" "$droid_args" "$src_pane" 2>/dev/null || true)"
    if [[ -n "$transcript_path" && -f "$transcript_path" ]]; then
      printf '%s\n' "$transcript_path" > "$tmpdir/transcript_path"
      maybe_prepare_menu "$transcript_path" "$vim_offset"
      debug_log "seed.capture profile=$src_profile pid=${droid_pid:-none} tty=${droid_tty:-none} transcript_path=$transcript_path offset=$vim_offset menu_mode=$menu_mode bytes=$(wc -c < "$msg_file" | tr -d '[:space:]')"
    else
      : > "$msg_file"
      debug_log "seed.blank profile=$src_profile reason=missing_droid_transcript pid=${droid_pid:-none} tty=${droid_tty:-none}"
    fi
  else
    : > "$msg_file"
    debug_log "seed.blank profile=$src_profile reason=missing_session_transcript"
  fi
else
  : > "$msg_file"
  debug_log "seed.blank"
fi

cp "$msg_file" "$orig_file"
debug_log "command.open_window msg_bytes=$(wc -c < "$msg_file" | tr -d '[:space:]') orig_bytes=$(wc -c < "$orig_file" | tr -d '[:space:]') debug_log=$debug_log_file"
open_vim_tmux_popup
