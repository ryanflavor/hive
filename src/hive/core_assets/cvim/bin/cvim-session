#!/usr/bin/env python3
from __future__ import annotations

import sys

from _cvim_shared import resolve_transcript_path_for_pane


def main() -> int:
    args = sys.argv[1:]
    if len(args) not in {2, 3}:
        raise SystemExit("usage: cvim-session <cwd> <droid_args> [pane_id]")

    transcript_path = resolve_transcript_path_for_pane(
        cwd=args[0],
        droid_args=args[1],
        pane_id=args[2] if len(args) == 3 else "",
    )
    if transcript_path:
        print(transcript_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
