#!/usr/bin/env python3
from __future__ import annotations

import difflib
import json
import sys
from pathlib import Path
from typing import Any

from _cvim_shared import resolve_assistant_offset


def _protocol(script_path: Path) -> dict[str, Any]:
    path = script_path.resolve().parent.parent / "resources" / "cvim_edit_protocol.json"
    return json.loads(path.read_text())


def _resolve_target(protocol: dict[str, Any], offset: int) -> str:
    if offset <= 0:
        return protocol["defaultTarget"]
    return protocol["offsetTargetFormat"].replace("{n}", str(offset + 1))


def _build_hunks_only_diff(orig: str, edited: str) -> str:
    raw = difflib.unified_diff(
        orig.splitlines(True),
        edited.splitlines(True),
        fromfile="",
        tofile="",
    )
    lines = [line for line in raw if not line.startswith("--- ") and not line.startswith("+++ ")]
    return "".join(lines).rstrip("\n")


def _build_payload(orig: str, edited: str, mode: str, protocol: dict[str, Any], offset: int = 0) -> str:
    if mode == "diff":
        tag = protocol["tag"]
        attr = protocol["onAttr"]
        target = _resolve_target(protocol, offset)
        diff = _build_hunks_only_diff(orig, edited)
        return f"<{tag} {attr}=\"{target}\">\n{diff}\n</{tag}>"
    return edited.rstrip("\n")


def main() -> int:
    orig = Path(sys.argv[1]).read_text(errors="ignore")
    edited = Path(sys.argv[2]).read_text(errors="ignore")
    dst = Path(sys.argv[3])
    mode = sys.argv[4]
    offset = 0
    tmpdir = dst.parent
    offset_file = tmpdir / "offset"
    transcript_path_file = tmpdir / "transcript_path"
    menu_selected_file = tmpdir / "menu_selected"
    if offset_file.is_file():
        try:
            offset = int(offset_file.read_text().strip())
        except (ValueError, OSError):
            pass
    if not menu_selected_file.is_file() and transcript_path_file.is_file():
        try:
            offset = resolve_assistant_offset(Path(transcript_path_file.read_text().strip()), offset=offset)
        except OSError:
            pass
    payload = _build_payload(orig, edited, mode, _protocol(Path(__file__)), offset=offset)
    dst.write_text(payload[:-1] if payload.endswith("\n") else payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
